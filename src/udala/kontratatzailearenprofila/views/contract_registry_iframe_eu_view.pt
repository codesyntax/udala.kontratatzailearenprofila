<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml"
      lang="eu"
      xml:lang="eu"
>
  <head>
    <meta charset="UTF-8" />
    <link href="${here/portal_url}/++plone++udala.kontratatzailearenprofila/widgetContratos/ac70cEstilos.css"
          rel="stylesheet"
          type="text/css"
    />
    <link href="${here/portal_url}/++plone++udala.kontratatzailearenprofila/widgetContratos/jquery.dataTables.1.9.0.css"
          rel="stylesheet"
          type="text/css"
    />
    <link href="${here/portal_url}/++plone++udala.kontratatzailearenprofila/widgetContratos/jquery.dataTables.themeroller.css"
          rel="stylesheet"
          type="text/css"
    />
    <script src="${here/portal_url}/++plone++udala.kontratatzailearenprofila/widgetContratos/jquery-3.6.0.min.js"
            type="text/javascript"
    ></script>
    <script src="${here/portal_url}/++plone++udala.kontratatzailearenprofila/widgetContratos/jquery.dataTables.1.9.0.min.js"
            type="text/javascript"
    ></script>
    <script src="${here/portal_url}/++plone++udala.kontratatzailearenprofila/widgetContratos/ac70cConfigurador.js"
            type="text/javascript"
    ></script>
    <script src="${here/portal_url}/++plone++udala.kontratatzailearenprofila/widgetContratos/ac70cFecha.js"
            type="text/javascript"
    ></script>
    <link href="${context/absolute_url}/custom.css"
          rel="stylesheet"
          type="text/css"
    />
  </head>
  <body>
    <div id="loading-overlay"></div>

    <!-- ESTADOS -->
    <ul id="agruEstado"
        style="visibility: hidden"
    >
      <li class="selected">
        <a id="estado-tc"
           href="#"
        >Kontratu guztiak</a>
        <script type="text/javascript">
          $("a#estado-tc").click(function () {
            $("#estado").attr("value", "");
            $("#titulo").attr("value", "Kontratu guztiak");
            $("#agruEstado li").removeClass("selected");
            $(this).parent().addClass("selected");
            $("#jswidget").html("");
            C.iniciar();
            return false;
          });
        </script>
      </li>
      <li>
        <a id="estado-ce"
           href="#"
        >Egiten ari direnak</a>
        <script type="text/javascript">
          $("a#estado-ce").click(function () {
            $("#estado").attr("value", "4");
            $("#titulo").attr("value", "Egiten ari diren kontratuak");
            $("#agruEstado li").removeClass("selected");
            $(this).parent().addClass("selected");
            $("#jswidget").html("");
            C.iniciar();
            return false;
          });
        </script>
      </li>
      <li>
        <a id="estado-cf"
           href="#"
        >Bukatuak</a>
        <script type="text/javascript">
          $("a#estado-cf").click(function () {
            $("#estado").attr("value", "5");
            $("#titulo").attr("value", "Bukatutako kontratuak");
            $("#agruEstado li").removeClass("selected");
            $(this).parent().addClass("selected");
            $("#jswidget").html("");
            C.iniciar();
            return false;
          });
        </script>
      </li>

      <li>
        <a id="estado-cm"
           href="#"
        >Kontratu txikiak</a>
        <script type="text/javascript">
          $("a#estado-cm").click(function () {
            $("#contratosMenores").attr("value", "TRUE");
            $("#estado").attr("value", "");
            $("#titulo").attr("value", "Kontratu txikiak");
            $("#agruEstado li").removeClass("selected");
            $(this).parent().addClass("selected");
            $("#jswidget").html("");
            C.iniciar();
            return false;
          });
        </script>
      </li>
    </ul>

    <ul id="agruTipoContrato"
        style="visibility: hidden"
    >
      <li class="selected">
        <a id="tipoContrato-tc"
           href="#"
        >Kontratu guztiak</a>
        <script type="text/javascript">
          $("a#tipoContrato-tc").click(function () {
            $("#tipoContrato").attr("value", "");
            $("#contratosMenores").attr("value", "FALSE");
            $("#titulo").attr("value", "Kontratu guztiak");
            $("#agruTipoContrato li").removeClass("selected");
            $(this).parent().addClass("selected");
            $("#jswidget").html("");
            C.iniciar();
            return false;
          });
        </script>
      </li>
      <li>
        <a id="tipoContrato-o"
           href="#"
        >Obrak</a>
        <script type="text/javascript">
          $("a#tipoContrato-o").click(function () {
            $("#tipoContrato").attr("value", "1");
            $("#contratosMenores").attr("value", "FALSE");
            $("#titulo").attr("value", "Obretako kontratuak");
            $("#agruTipoContrato li").removeClass("selected");
            $(this).parent().addClass("selected");
            $("#jswidget").html("");
            C.iniciar();
            return false;
          });
        </script>
      </li>
      <li>
        <a id="tipoContrato-se"
           href="#"
        >Zerbitzuak</a>
        <script type="text/javascript">
          $("a#tipoContrato-se").click(function () {
            $("#tipoContrato").attr("value", "2");
            $("#contratosMenores").attr("value", "FALSE");
            $("#titulo").attr("value", "Zerbitzuetako kontratuak");
            $("#agruTipoContrato li").removeClass("selected");
            $(this).parent().addClass("selected");
            $("#jswidget").html("");
            C.iniciar();
            return false;
          });
        </script>
      </li>
      <li>
        <a id="tipoContrato-su"
           href="#"
        >Hornigaiak</a>
        <script type="text/javascript">
          $("a#tipoContrato-su").click(function () {
            $("#tipoContrato").attr("value", "3");
            $("#contratosMenores").attr("value", "FALSE");
            $("#titulo").attr("value", "Hornigaietako kontratuak");
            $("#agruTipoContrato li").removeClass("selected");
            $(this).parent().addClass("selected");
            $("#jswidget").html("");
            C.iniciar();
            return false;
          });
        </script>
      </li>
      <li>
        <a id="tipoContrato-ae"
           href="#"
        >Administratibo bereziak</a>
        <script type="text/javascript">
          $("a#tipoContrato-ae").click(function () {
            $("#tipoContrato").attr("value", "4");
            $("#contratosMenores").attr("value", "FALSE");
            $("#titulo").attr("value", "Administratibo berezietako kontratuak");
            $("#agruTipoContrato li").removeClass("selected");
            $(this).parent().addClass("selected");
            $("#jswidget").html("");
            C.iniciar();
            return false;
          });
        </script>
      </li>
      <li>
        <a id="tipoContrato-cop"
           href="#"
        >Obra publikoaren kontzesioa</a>
        <script type="text/javascript">
          $("a#tipoContrato-cop").click(function () {
            $("#tipoContrato").attr("value", "5");
            $("#contratosMenores").attr("value", "FALSE");
            $("#titulo").attr(
              "value",
              "Obra publikoaren kontsezioetako kontratuak"
            );
            $("#agruTipoContrato li").removeClass("selected");
            $(this).parent().addClass("selected");
            $("#jswidget").html("");
            C.iniciar();
            return false;
          });
        </script>
      </li>
      <li>
        <a id="tipoContrato-gsp"
           href="#"
        >Zerbitzu publikoen kudeaketa</a>
        <script type="text/javascript">
          $("a#tipoContrato-gsp").click(function () {
            $("#tipoContrato").attr("value", "6");
            $("#contratosMenores").attr("value", "FALSE");
            $("#titulo").attr(
              "value",
              "Zerbitzu publikoen kudeaketako kontratuak "
            );
            $("#agruTipoContrato li").removeClass("selected");
            $(this).parent().addClass("selected");
            $("#jswidget").html("");
            C.iniciar();
            return false;
          });
        </script>
      </li>
      <li>
        <a id="tipoContrato-cspsp"
           href="#"
        >Sektore publikoaren eta pribatuaren arteko kolaborazioa</a>
        <script type="text/javascript">
          $("a#tipoContrato-cspsp").click(function () {
            $("#tipoContrato").attr("value", "7");
            $("#contratosMenores").attr("value", "FALSE");
            $("#titulo").attr(
              "value",
              "Sektore publikoaren eta pribatuaren arteko kolaborazioetako kontratuak"
            );
            $("#agruTipoContrato li").removeClass("selected");
            $(this).parent().addClass("selected");
            $("#jswidget").html("");
            C.iniciar();
            return false;
          });
        </script>
      </li>
      <li>
        <a id="tipoContrato-p"
           href="#"
        >Pribatuak</a>
        <script type="text/javascript">
          $("a#tipoContrato-p").click(function () {
            $("#tipoContrato").attr("value", "1041");
            $("#contratosMenores").attr("value", "FALSE");
            $("#titulo").attr("value", "Kontratu pribatuak");
            $("#agruTipoContrato li").removeClass("selected");
            $(this).parent().addClass("selected");
            $("#jswidget").html("");
            C.iniciar();
            return false;
          });
        </script>
      </li>

      <li>
        <a id="tipoContrato-cm"
           href="#"
        >Kontratu txikiak</a>
        <script type="text/javascript">
          $("a#tipoContrato-cm").click(function () {
            $("#tipoContrato").attr("value", "");
            $("#contratosMenores").attr("value", "TRUE");
            $("#titulo").attr("value", "Kontratu txikiak");
            $("#agruTipoContrato li").removeClass("selected");
            $(this).parent().addClass("selected");
            $("#jswidget").html("");
            C.iniciar();
            return false;
          });
        </script>
      </li>
    </ul>

    <br />

    <form id="opciones"
          method="_GET"
    >
      <input id="idioma"
             type="hidden"
             value="eu"
      />
      <input id="poder"
             type="hidden"
             value="${context/code}"
      />
      <input id="agrupacion"
             type="hidden"
             value=""
      />
      <input id="estado"
             type="hidden"
             value=""
      />
      <input id="tipoContrato"
             type="hidden"
             value=""
      />
      <input id="contratosMenores"
             type="hidden"
             value=""
      />
      <input id="numResult"
             type="hidden"
             value=""
      />
      <input id="entidad"
             type="hidden"
             value=""
      />
      <input id="titulo"
             type="hidden"
             value=""
      />

      <div style="display: none">
        <input id="actualizar"
               name="actualizar"
               style="visibility: hidden"
               type="button"
               value="actualizar"
        />
        <input id="probar"
               name="probar"
               style="visibility: hidden"
               type="button"
               value="probar"
        />
      </div>
    </form>

    <div class="widget"
         id="jswidget"
    ></div>
  </body>
</html>
