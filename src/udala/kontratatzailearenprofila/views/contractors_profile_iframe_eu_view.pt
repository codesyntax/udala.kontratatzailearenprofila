    <br />

    <form id="opciones"
          method="_GET"
    >
      <input id="idioma"
             type="hidden"
             value="eu"
      />
      <input id="poder"
             type="hidden"
             value="${context/code}"
      />
      <input id="entidad"
             type="hidden"
             value=""
      />

      <input id="agrupacion"
             type="hidden"
             value=""
      />
      <input id="estado"
             type="hidden"
             value=""
      />
      <input id="tipoContrato"
             type="hidden"
             value=""
      />
      <input id="numResult"
             type="hidden"
             value=""
      />

      <input id="titulo"
             type="hidden"
             value=""
      />

      <input id="restricciones"
             type="hidden"
             value="false"
      />

      <!-- Caso últimas licitaciones -->

      <input id="tipoInformacion"
             type="hidden"
             value="al"
      />

      <div style="display: none">
        <input id="actualizar"
               name="actualizar"
               style="visibility: hidden"
               type="button"
               value="actualizar"
        />
        <input id="probar"
               name="probar"
               style="visibility: hidden"
               type="button"
               value="probar"
        />
      </div>
    </form>
    <div class="widget"
         id="jswidget"
    ></div>
