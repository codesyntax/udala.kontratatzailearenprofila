      >
        <a id="licitacion-ta"
           href="#"
        >Iragarki guztiak</a>
        <script type="text/javascript">
          $("a#licitacion-ta").click(function () {
            $("#tipoInformacion").attr("value", "ta");
            $("#titulo").attr("value", "Iragarki guztiak");
            $("#tipo_licitaciones li").removeClass("selected");
            $(this).parent().addClass("selected");
            $("#jswidget").html("");
            C.iniciar();
            return false;
          });
        </script>
      </li>
